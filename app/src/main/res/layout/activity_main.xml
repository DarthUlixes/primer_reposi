<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/menta"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Escribe un texto"
            android:textColor="@color/menta"
            android:textColorHint="#88FFFFFF" />

        <Button
            android:id="@+id/btnMostrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/menta"
            android:text="Mostrar Texto"
            android:textColor="@color/negro" />

        <TextView
            android:id="@+id/txtResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/gris_oscuro"
            android:padding="12dp"
            android:text="Aquí aparecerá el texto"
            android:textColor="@color/menta"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/menta"
            android:text="@string/abrir_chat"
            android:textColor="@color/negro" />

        <Button
            android:id="@+id/btnGuardarApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#FF9800"
            android:text="Guardar en API (POST)"
            android:textColor="@color/negro" />

        <Button
            android:id="@+id/btnConsultarApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#03A9F4"
            android:text="Consultar API (GET)"
            android:textColor="@color/negro" />

        <TextView
            android:id="@+id/txtApiResultados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1AFFFFFF"
            android:padding="8dp"
            android:text="Los resultados aparecerán aquí"
            android:textColor="#BBFFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnCargarMas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#4CAF50"
            android:text="Cargar todos"
            android:visibility="gone"
            android:textColor="@color/negro" />

    </LinearLayout>

</ScrollView>
