<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/chat_esperando_celular"
            android:textColor="@color/menta"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtDiag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="#88FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/chat_recibidos"
            android:textColor="@color/menta"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtRecibidos"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="4dp"
            android:background="@color/gris_oscuro"
            android:gravity="top|center_horizontal"
            android:padding="6dp"
            android:text="@string/chat_sin_mensajes"
            android:textColor="@color/menta"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/edtMensaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/chat_escribe_mensaje"
            android:inputType="text"
            android:textColor="@color/menta"
            android:textColorHint="#88FFFFFF" />

        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:backgroundTint="@color/menta"
            android:enabled="false"
            android:minHeight="40dp"
            android:text="@string/chat_enviar"
            android:textColor="@color/negro" />

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:backgroundTint="@color/menta"
            android:minHeight="40dp"
            android:text="@string/chat_volver"
            android:textColor="@color/negro" />

    </LinearLayout>

</ScrollView>
